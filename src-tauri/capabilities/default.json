{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for FlowNote",
  "windows": ["main", "editor-*", "floating-*", "screenshot-*", "reminder-*", "edgedock-*", "editor-dock-*", "image-preview-*", "tray-menu", "settings", "area-select-*", "update-dialog"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-minimize",
    "core:window:allow-set-always-on-top",
    "core:window:allow-start-dragging",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-set-focus",
    "core:window:allow-outer-size",
    "core:window:allow-inner-size",
    "core:window:allow-outer-position",
    "core:window:allow-inner-position",
    "core:window:allow-available-monitors",
    "core:window:allow-current-monitor",
    "core:window:allow-set-fullscreen",
    "core:window:allow-monitor-from-point",
    "core:window:allow-cursor-position",
    "core:window:allow-set-ignore-cursor-events",
    "core:event:default",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-create-webview",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-temp-write",
    "fs:allow-read-file",
    "fs:allow-exists",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$APPLOCALDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "**" }
      ]
    },
    "shell:default",
    "global-shortcut:default",
    "notification:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-image",
    "clipboard-manager:allow-read-image"
  ]
}
