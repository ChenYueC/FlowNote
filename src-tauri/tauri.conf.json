{
  "productName": "FlowNote",
  "version": "0.5.1",
  "identifier": "com.flownote.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1520",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "FlowNote",
        "width": 360,
        "height": 680,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": false,
        "skipTaskbar": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https: data: blob:; font-src 'self' data:; connect-src 'self' https://api.github.com https://raw.githubusercontent.com https://github.com http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "copyright": "© Chenyue",
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"],
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
